# Environment Configuration
# Set to LOCAL, TESTNET_STAGING, TESTNET_PROD, or MAINNET_PROD
ENV=LOCAL

# ============ LOCAL Environment Variables ============
# Required for LOCAL environment deployments
LOCAL_CREATE2_FACTORY_ADDRESS=
LOCAL_DEPLOYER_ADDRESS=
# Private key for local testing (never use real private keys in .env files)
LOCAL_DEPLOYER_KEY=

# ============ Network Configuration ============
# RPC URL for the selected environment
RPC_URL=http://localhost:8545

# ============ xReserve Configuration ============
# Owner address for the xReserve contract (uses 2-step ownership transfer)
X_RESERVE_OWNER_ADDRESS=

# Set to true if the two-step ownership transfer has been completed
X_RESERVE_OWNERSHIP_TRANSFER_COMPLETED=false

# Access control addresses
X_RESERVE_PAUSER_ADDRESS=
X_RESERVE_BLOCKLISTER_ADDRESS=
X_RESERVE_REGISTRATION_MANAGER_ADDRESS=

# Constructor dependencies - immutable addresses embedded in implementation
X_RESERVE_GATEWAY_MINTER_ADDRESS=
X_RESERVE_GATEWAY_WALLET_ADDRESS=
X_RESERVE_TOKEN_MESSENGER_ADDRESS=
X_RESERVE_TOKEN_MESSENGER_V2_ADDRESS=

# Domain configuration
X_RESERVE_DOMAIN=0

# Supported tokens (supports up to 1 token)
# The deployment script will automatically detect and include all sequentially numbered tokens
X_RESERVE_SUPPORTED_TOKEN_1=

# ============ Deployed Addresses (for validation scripts) ============
# Set these after deployment when running validation scripts 002 and 003
X_RESERVE_PROXY_ADDRESS=
X_RESERVE_IMPL_ADDRESS=
X_RESERVE_REMOTE_DOMAIN_DEPOSITOR_IMPL_ADDRESS=
UPGRADEABLE_PLACEHOLDER_IMPL_ADDRESS=

# ============ Verification Configuration ============
# Etherscan API key (works for both Ethereum mainnet and Sepolia testnet)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Optional: limit for event verifier token scan
MAX_SUPPORTED_TOKENS=100

# ============ Remote Domain Registration (script 005) ============
# Multi-domain (indexed) variables only. The script iterates
# X_RESERVE_REMOTE_DOMAIN_{i} for i=1..N and stops at the first missing index.
# For each domain i, set the following variables:
X_RESERVE_REMOTE_DOMAIN_1=
X_RESERVE_REMOTE_DOMAIN_1_MANAGER_ADDRESS=
X_RESERVE_REMOTE_DOMAIN_1_PAUSER_ADDRESS=
X_RESERVE_REMOTE_DOMAIN_1_SIGNATURE_THRESHOLD=
X_RESERVE_REMOTE_DOMAIN_1_PERSISTENT_SIGNATURE_BUFFER_DELAY_BLOCKS=

# Optional
X_RESERVE_REMOTE_DOMAIN_1_HOOK_EXECUTOR_ADDRESS=

X_RESERVE_REMOTE_DOMAIN_1_ATTESTER_1=
X_RESERVE_REMOTE_DOMAIN_1_ATTESTER_2=
# Add X_RESERVE_REMOTE_DOMAIN_2_*, X_RESERVE_REMOTE_DOMAIN_3_*, etc. as needed

X_RESERVE_REMOTE_DOMAIN_1_LOCAL_TOKEN=
X_RESERVE_REMOTE_DOMAIN_1_REMOTE_TOKEN=
