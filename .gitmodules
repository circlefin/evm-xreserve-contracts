[submodule "lib/forge-std"]
	path = lib/forge-std
	url = https://github.com/foundry-rs/forge-std.git
[submodule "lib/openzeppelin-contracts-upgradeable"]
	path = lib/openzeppelin-contracts-upgradeable
	url = https://github.com/OpenZeppelin/openzeppelin-contracts-upgradeable.git
[submodule "lib/openzeppelin-contracts"]
	path = lib/openzeppelin-contracts
	url = https://github.com/OpenZeppelin/openzeppelin-contracts.git
[submodule "lib/evm-gateway-contracts"]
	path = lib/evm-gateway-contracts
	url = git@github.com:circlefin/evm-gateway-contracts.git
	ignore = dirty
[submodule "lib/evm-cctp-contracts"]
	path = lib/evm-cctp-contracts
	url = https://github.com/circlefin/evm-cctp-contracts.git
	ignore = dirty
[submodule "lib/memview-sol"]
	path = lib/memview-sol
	url = https://github.com/LayneHaber/memview-sol.git
